# config.env
# ----------------------------
# REQUIRED
AWS_REGION="ap-south-1"
PROJECT_NAME="geoai"
STACK_NAME="geoai-lgbm-group6"

INGEST_STACK_NAME="geoai-lgbm-group6-ingest"

# S3 bucket where model.tar.gz will be uploaded (and/or artifact bucket used by stack)
MODEL_BUCKET="geoai-model-bucket"
MODEL_S3_KEY="geoai/model.tar.gz"

# Bucket used to store Lambda assets zip referenced by CloudFormation
LAMBDA_ASSETS_BUCKET="geoai-lambda-assets-bucket"

# Feature CSV folder to upload as batch inputs
FEATURE_INPUT_DIR="../data/features_frozen"

# LightGBM model + feature list (local paths)
MODEL_PKL_PATH="./model_artifacts/model.pkl"
FEATURE_LIST_PATH="./model_artifacts/feature_names.json"

# ECR repo + tag
ECR_REPO="geoai-lgbm-group6-inference"
ECR_EVAL_REPO="geoai-lgbm-group6-evalprocess"
ECR_COMPARE_REPO="geoai-lgbm-group6-compareprocess"
ECR_INGEST_REPO="geoai-lgbm-group6-ingestprocess"
ECR_TAG="v1"

# OPTIONAL (for restricted IAM accounts)
# If set, deploy_stack.sh will use this instead of creating SageMaker execution role
EXISTING_SAGEMAKER_EXEC_ROLE_ARN=""

# OPTIONAL: if your deploy script outputs the artifacts bucket, you can leave ARTIFACTS_BUCKET empty.
# Otherwise set it explicitly (some stacks use separate bucket for batch I/O)
ARTIFACTS_BUCKET="geoai-artifact-bucket"

# OPTIONAL: Skip certain steps (true/false)
SKIP_PACKAGE_MODEL="true"
SKIP_UPLOAD_MODEL="true"
SKIP_BUILD_PUSH_ECR="true"
SKIP_BUILD_PUSH_ECR_EVAL="true"
SKIP_BUILD_PUSH_ECR_COMPARE="true"
SKIP_BUILD_PUSH_ECR_INGEST="true"
SKIP_DEPLOY_STACK="false"
SKIP_UPLOAD_INPUTS="true"